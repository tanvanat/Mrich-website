// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Response {
  id          String   @id @default(cuid())
  formId      String
  name        String
  answersJson String
  totalScore  Int
  maxScore    Int
  percent     Float
  level       String
  tip         String
  createdAt   DateTime @default(now())
}

